{
  "name": "fastify-starter",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch:ts\" \"npm:watch:node\"",
    "watch:ts": "tsc -p tsconfig.json --watch",
    "watch:node": "node --watch build/index.js",
    "build": "tsc -p tsconfig.json",
    "start": "node build/index.js"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/sensible": "^6.0.4",
    "@fastify/type-provider-typebox": "^6.1.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "concurrently": "^10.0.3",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3"
  },
  "author": "Saikat Sardar",
  "license": "MIT",
  "homepage": "https://github.com/MrSaikatS/fastify-starter#readme"
}
